{
  "name": "worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "generate-types": "wrangler types",
    "db:generate": "drizzle-kit generate --name isotope",
    "db:migrate": "wrangler d1 migrations apply isotope-db --remote",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@app/schemas": "workspace:*",
    "@clerk/backend": "^1.0.0",
    "@hono/zod-validator": "^0.8.0",
    "@logtape/hono": "^2.0.0",
    "@logtape/logtape": "^2.0.0",
    "@logtape/redaction": "^2.0.0",
    "dayjs": "^1.0.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@types/node": "^25.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.0.0"
  }
}
